# TRUST.AI Local Environment Configuration
# Copy this file to .env.local and update values as needed

# Backend URL for API calls
# Use http://localhost:8000 for local development
# Use https://your-backend-domain.com for production
BACKEND_URL=http://localhost:8000

# Optional: Enable debug logging (frontend)
# DEBUG=trust-ai:*

# Optional: API timeout (milliseconds)
# API_TIMEOUT=30000
